{
  "company_info": {
    "request": {
      "id": "CompanyInfo",
      "collection_name": "CompanyInfo",
      "object_type": "Company",
      "fetch": [
        "NAME",
        "BOOKSFROM",
        "BOOKSTO",
        "GUID",
        "MASTERID",
        "BASICCOMPANYADDRESS",
        "STATENAME",
        "COUNTRYNAME",
        "PINCODE",
        "EMAIL",
        "PHONENUMBER",
        "GSTREGISTRATIONTYPE",
        "PARTYGSTIN",
        "INCOMETAXNUMBER"
      ],
      "filters": [
        "NonAggrFilter"
      ],
      "system_formulae": [
        {
          "name": "NonAggrFilter",
          "expression": "$isaggregate = \"No\""
        }
      ]
    },
    "response": {
      "mode": "single",
      "row_tag": "COMPANY",
      "fields": {
        "name": {
          "sources": [
            "NAME",
            "@NAME"
          ],
          "transform": "string"
        },
        "books_from": {
          "sources": [
            "BOOKSFROM"
          ],
          "transform": "date"
        },
        "books_to": {
          "sources": [
            "BOOKSTO"
          ],
          "transform": "date"
        },
        "books_from_raw": {
          "sources": [
            "BOOKSFROM"
          ],
          "transform": "string"
        },
        "books_to_raw": {
          "sources": [
            "BOOKSTO"
          ],
          "transform": "string"
        },
        "guid": {
          "sources": [
            "GUID"
          ],
          "transform": "string"
        },
        "master_id": {
          "sources": [
            "MASTERID"
          ],
          "transform": "int"
        },
        "address": {
          "sources": [
            "BASICCOMPANYADDRESS"
          ],
          "transform": "string"
        },
        "state": {
          "sources": [
            "STATENAME"
          ],
          "transform": "string"
        },
        "country": {
          "sources": [
            "COUNTRYNAME"
          ],
          "transform": "string"
        },
        "pincode": {
          "sources": [
            "PINCODE"
          ],
          "transform": "string"
        },
        "email": {
          "sources": [
            "EMAIL"
          ],
          "transform": "string"
        },
        "phone": {
          "sources": [
            "PHONENUMBER"
          ],
          "transform": "string"
        },
        "gst_type": {
          "sources": [
            "GSTREGISTRATIONTYPE"
          ],
          "transform": "string"
        },
        "gstin": {
          "sources": [
            "PARTYGSTIN"
          ],
          "transform": "string"
        },
        "pan": {
          "sources": [
            "INCOMETAXNUMBER"
          ],
          "transform": "string"
        }
      }
    }
  },
