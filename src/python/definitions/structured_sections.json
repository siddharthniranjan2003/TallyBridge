  "vouchers": {
    "request": {
      "id": "AllVouchers",
      "collection_name": "AllVouchers",
      "object_type": "Voucher",
      "fetch": [
        "GUID",
        "DATE",
        "VOUCHERTYPENAME",
        "VOUCHERNUMBER",
        "PARTYLEDGERNAME",
        "AMOUNT",
        "REFERENCE",
        "PERSISTEDVIEW",
        "ISINVOICE",
        "ISCANCELLED",
        "NARRATION",
        "ALLINVENTORYENTRIES",
        "ALLLEDGERENTRIES"
      ],
      "filters": [
        "NotCancelledVouchers",
        "NotOptionalVouchers"
      ],
      "system_formulae": [
        {
          "name": "NotCancelledVouchers",
          "expression": "NOT $IsCancelled"
        },
        {
          "name": "NotOptionalVouchers",
          "expression": "NOT $IsOptional"
        }
      ],
      "static_variables": [
        {
          "name": "SVFROMDATE",
          "value": "{{from_date}}"
        },
        {
          "name": "SVTODATE",
          "value": "{{to_date}}"
        }
      ]
    },
    "response": {
      "mode": "list",
      "row_path_options": [
        "ENVELOPE.BODY.DATA.COLLECTION.VOUCHER",
        "messages.VOUCHER"
      ],
      "required_field": "tally_guid",
      "fields": {
        "tally_guid": {
          "sources": [
            "@REMOTEID",
            "GUID"
          ],
          "transform": "string"
        },
        "voucher_number": {
          "sources": [
            "VOUCHERNUMBER"
          ],
          "transform": "string"
        },
        "voucher_type": {
          "sources": [
            "@VCHTYPE",
            "VOUCHERTYPENAME"
          ],
          "transform": "string"
        },
        "date": {
          "sources": [
            "DATE"
          ],
          "transform": "date"
        },
        "party_name": {
          "sources": [
            "PARTYLEDGERNAME"
          ],
          "transform": "string"
        },
        "amount": {
          "sources": [
            "AMOUNT"
          ],
          "transform": "float"
        },
        "narration": {
          "sources": [
            "NARRATION"
          ],
          "transform": "string"
        },
        "is_cancelled": {
          "sources": [
            "ISCANCELLED"
          ],
          "transform": "bool_yesno"
        },
        "reference": {
          "sources": [
            "REFERENCE"
          ],
          "transform": "string"
        },
        "is_invoice": {
          "sources": [
            "ISINVOICE"
          ],
          "transform": "bool_yesno"
        },
        "view": {
          "sources": [
            "PERSISTEDVIEW",
            "@OBJVIEW"
          ],
          "transform": "string"
        }
      },
      "children": [
        {
          "name": "items",
          "source_paths": [
            "ALLINVENTORYENTRIES.LIST",
            "INVENTORYENTRIES.LIST"
          ],
          "required_field": "stock_item_name",
          "fields": {
            "stock_item_name": {
              "sources": [
                "STOCKITEMNAME"
              ],
              "transform": "string"
            },
            "quantity": {
              "sources": [
                "ACTUALQTY"
              ],
              "transform": "quantity_value_abs"
            },
            "unit": {
              "sources": [
                "ACTUALQTY"
              ],
              "transform": "quantity_unit",
              "default": "Nos"
            },
            "rate": {
              "sources": [
                "RATE"
              ],
              "transform": "float"
            },
            "discount_pct": {
              "sources": [
                "DISCOUNT"
              ],
              "transform": "float"
            },
            "amount": {
              "sources": [
                "AMOUNT"
              ],
              "transform": "float"
            }
          }
        },
        {
          "name": "ledger_entries",
          "source_paths": [
            "ALLLEDGERENTRIES.LIST",
            "LEDGERENTRIES.LIST"
          ],
          "required_field": "ledger_name",
          "fields": {
            "ledger_name": {
              "sources": [
                "LEDGERNAME"
              ],
              "transform": "string"
            },
            "amount": {
              "sources": [
                "AMOUNT"
              ],
              "transform": "float"
            },
            "is_party_ledger": {
              "sources": [
                "ISPARTYLEDGER"
              ],
              "transform": "bool_yesno"
            },
            "is_deemed_positive": {
              "sources": [
                "ISDEEMEDPOSITIVE"
              ],
              "transform": "bool_yesno"
            }
          },
          "children": [
            {
              "name": "bill_allocations",
              "source_paths": [
                "BILLALLOCATIONS.LIST"
              ],
              "fields": {
                "name": {
                  "sources": [
                    "NAME"
                  ],
                  "transform": "string"
                },
                "bill_type": {
                  "sources": [
                    "BILLTYPE"
                  ],
                  "transform": "string"
                },
                "amount": {
                  "sources": [
                    "AMOUNT"
                  ],
                  "transform": "float"
                }
              }
            }
          ]
        }
      ]
    }
  },
