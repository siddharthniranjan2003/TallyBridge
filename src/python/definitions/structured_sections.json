  "stock_items": {
    "request": {
      "id": "StockItemSummary",
      "collection_name": "StockItemSummary",
      "object_type": "StockItem",
      "fetch": [
        "NAME",
        "PARENT",
        "BASEUNITS",
        "CLOSINGBALANCE",
        "CLOSINGVALUE",
        "CLOSINGRATE"
      ]
    },
    "response": {
      "mode": "list",
      "row_tag": "STOCKITEM",
      "required_field": "name",
      "fields": {
        "name": {
          "sources": [
            "NAME",
            "@NAME"
          ],
          "transform": "string"
        },
        "group_name": {
          "sources": [
            "PARENT"
          ],
          "transform": "string"
        },
